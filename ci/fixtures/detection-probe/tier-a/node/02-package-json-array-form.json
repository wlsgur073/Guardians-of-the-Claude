{
  "name": "tier-a/node/02-package-json-array-form",
  "ecosystem": "node",
  "spec_ref": "monorepo-detection §1.1",
  "description": "Array form of package.json workspaces field with glob.",
  "input": {
    "manifests": {
      "package.json": "{\n  \"name\": \"root\",\n  \"private\": true,\n  \"workspaces\": [\"packages/*\"]\n}\n",
      "packages/foo/package.json": "{ \"name\": \"@org/foo\" }\n",
      "packages/bar/package.json": "{ \"name\": \"@org/bar\" }\n"
    },
    "directories": ["packages/foo", "packages/bar"]
  },
  "expected": {
    "detected": true,
    "evidence_types": ["workspace_declaration"],
    "package_roots_count": 2,
    "type": "monorepo",
    "notes_codes": []
  }
}
