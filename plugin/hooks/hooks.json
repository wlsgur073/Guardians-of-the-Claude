{
  "description": "Suggests running /claude-code-template:create when no Claude Code configuration is found",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "statusMessage": "Checking for Claude Code configuration"
          }
        ]
      }
    ]
  }
}
