{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Recommendations",
  "description": "Drift advisories (/audit model-drift surface) are transient output rendered by the drift advisory state machine and are NOT persisted as registry entries. Drift advisories MUST NOT have entries in recommendation-registry.json and MUST NOT be added to recommendations.json by any merge pass.",
  "type": "object",
  "required": ["schema_version", "metadata", "recommendations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "metadata": {
      "type": "object",
      "required": ["last_updated"],
      "properties": { "last_updated": { "type": "string", "format": "date-time" } },
      "additionalProperties": false
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "issued_by", "status", "pending_count", "first_seen", "last_seen"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string", "minLength": 1 },
          "issued_by": { "enum": ["audit", "create", "secure", "optimize"] },
          "status": { "enum": ["PENDING", "RESOLVED", "DECLINED", "STALE"] },
          "pending_count": { "type": "integer", "minimum": 0 },
          "first_seen": { "type": "string", "format": "date-time" },
          "last_seen": { "type": "string", "format": "date-time" },
          "resolved_by": { "enum": ["audit", "create", "secure", "optimize", null] },
          "declined_reason": { "type": ["string", "null"] }
        },
        "allOf": [
          {
            "$comment": "state-machine: status RESOLVED requires non-null resolved_by; non-RESOLVED requires null or absent",
            "if": { "properties": { "status": { "const": "RESOLVED" } }, "required": ["status"] },
            "then": {
              "required": ["resolved_by"],
              "properties": { "resolved_by": { "type": "string", "enum": ["audit", "create", "secure", "optimize"] } }
            },
            "else": {
              "properties": { "resolved_by": { "type": "null" } }
            }
          }
        ]
      }
    }
  }
}
